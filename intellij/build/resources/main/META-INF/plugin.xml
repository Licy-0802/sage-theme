<idea-plugin>
  <version>1.0.0</version>
  <idea-version since-build="241" />
  <id>com.licy.sage-theme</id>
  <name>Sage 鼠尾草</name>
  <vendor email="lichaoyu@smartcounselor.cn" url="https://github.com/Licy-0802/sage-theme">Licy</vendor>
  <description><![CDATA[鼠尾草绿护眼主题 — AI 时代，少写代码，多思考。
      A calming sage-green theme for the AI era.
      包含编辑器配色方案 + IDE 界面主题。
      Editor color scheme + full IDE UI theme included.]]></description>
  <depends>com.intellij.modules.platform</depends>
  <extensions defaultExtensionNs="com.intellij">
    <themeProvider id="sage-theme" path="/themes/sage.theme.json" />
  </extensions>
</idea-plugin>
